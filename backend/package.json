  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "mysql2": "3.11.5",
    "reflect-metadata": "0.2.2",
    "typeorm": "0.3.20",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jsonwebtoken": "9.0.7",
    "@types/multer": "1.4.12",
    "@types/node": "22.10.5",
    "@types/uuid": "10.0.0",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
